    <title>Ziya Samir Momin | AI & ML Engineering Portfolio</title>
    <meta name="description" content="Portfolio of Ziya Samir Momin, an AI & ML Engineering Student.">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&family=Outfit:wght@400;700&display=swap" rel="stylesheet">
    <!-- FontAwesome for Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Custom CSS -->
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

    <!-- Loading Screen -->
    <div id="loader">
        <div class="loader-circle"></div>
        <h2>LOADING...</h2>
    </div>

    <!-- Navigation -->
    <nav id="navbar">
        <div class="nav-container">
            <h1 class="logo">ZSM<span>.</span></h1>
            <ul class="nav-links">
                <li><a href="#hero">Home</a></li>
                <li><a href="#about">About</a></li>
                <li><a href="#education">Education</a></li>
                <li><a href="#skills">Skills</a></li>
                <li><a href="#projects">Projects</a></li>
                <li><a href="#contact">Contact</a></li>
            </ul>
            <div class="hamburger">
                <i class="fas fa-bars"></i>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <section id="hero" class="hero-section">
        <div class="particles" id="particles-js"></div>
        <div class="hero-content">
            <h2 class="slide-up">Hi, I'm</h2>
            <h1 class="glow-text slide-up delay-1">Ziya Samir Momin</h1>
            <h3 class="slide-up delay-2">I am a <span class="typing-text"></span></h3>
            <p class="slide-up delay-3">Passionate about building intelligent systems and modern web applications.</p>
            <div class="hero-buttons slide-up delay-4">
                <a href="#contact" class="btn btn-primary glow-btn">Contact Me</a>
                <a href="#" class="btn btn-secondary">Download Resume <i class="fas fa-download"></i></a>
            </div>
        </div>
        <div class="hero-image slide-up delay-2">
            <!-- Placeholder for profile image -->
            <div class="image-placeholder">
                <i class="fas fa-user-astronaut"></i>
            </div>
        </div>
        <a href="#about" class="scroll-down">
            <i class="fas fa-chevron-down"></i>
        </a>
    </section>

    <!-- About Me Section -->
    <section id="about" class="section fade-in">
        <h2 class="section-title">About <span>Me</span></h2>
        <div class="about-container glass-card">
            <p>
                Welcome to my portfolio! I am an ambitious engineering student currently pursuing my Diploma in Artificial Intelligence and Machine Learning at Rajarambapu Institute of Technology Polytechnic.
            </p>
            <p>
                My journey into technology began with a deep curiosity about how systems learn and adapt. Today, my career objective is to become a successful AI & ML Engineer and Full-Stack Developer, bridging the gap between intelligent algorithms and beautiful user interfaces.
            </p>
        </div>
    </section>

    <!-- Education Timeline Section -->
    <section id="education" class="section fade-in">
        <h2 class="section-title">Education <span>Timeline</span></h2>
        <div class="timeline">
            <div class="timeline-item left glass-card">
                <div class="timeline-content">
                    <h3>Diploma in AI & ML</h3>
                    <h4>Rajarambapu Institute of Technology Polytechnic, Lohagaon, Pune</h4>
                    <p class="timeline-date">Currently Pursuing</p>
                    <ul class="timeline-details">
                        <li>Winter 2025 Result: <span class="highlight">78%</span></li>
                        <li>Summer 2026 Result: <span class="highlight">74%</span></li>
                    </ul>
                </div>
            </div>
            <div class="timeline-item right glass-card">
                <div class="timeline-content">
                    <h3>SSC (10th)</h3>
                    <h4>Adarsh Secondary High School</h4>
                    <p class="timeline-date">Passed in 2025</p>
                    <ul class="timeline-details">
                        <li>Percentage: <span class="highlight">66%</span></li>
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <!-- Skills Section -->
    <section id="skills" class="section fade-in">
        <h2 class="section-title">Technical <span>Skills</span></h2>
        <div class="skills-container">
            <div class="skill-card glass-card">
                <div class="skill-info">
                    <span><i class="fab fa-cuttlefish"></i> C Programming</span>
                    <span>85%</span>
                </div>
                <div class="progress-bar"><div class="progress" data-width="85%"></div></div>
            </div>
            <div class="skill-card glass-card">
                <div class="skill-info">
                    <span><i class="fab fa-html5"></i> HTML</span>
                    <span>90%</span>
                </div>
                <div class="progress-bar"><div class="progress" data-width="90%"></div></div>
            </div>
            <div class="skill-card glass-card">
                <div class="skill-info">
                    <span><i class="fab fa-css3-alt"></i> CSS</span>
                    <span>80%</span>
                </div>
                <div class="progress-bar"><div class="progress" data-width="80%"></div></div>
            </div>
            <div class="skill-card glass-card">
                <div class="skill-info">
                    <span><i class="fas fa-code"></i> Web Development</span>
                    <span>75%</span>
                </div>
                <div class="progress-bar"><div class="progress" data-width="75%"></div></div>
            </div>
            <div class="skill-card glass-card">
                <div class="skill-info">
                    <span><i class="fab fa-linux"></i> Basic Linux</span>
                    <span>70%</span>
                </div>
                <div class="progress-bar"><div class="progress" data-width="70%"></div></div>
            </div>
        </div>
    </section>

    <!-- Achievements & Goals -->
    <section id="achievements" class="section fade-in">
        <h2 class="section-title">Achievements & <span>Goals</span></h2>
        <div class="ag-container">
            <div class="ag-box glass-card">
                <div class="icon"><i class="fas fa-trophy"></i></div>
                <h3>Achievements</h3>
                <ul>
                    <li>Participated in Kaizen activity.</li>
                    <li>Received Kaizen Certificate.</li>
                    <li>Consistent Academic Performance.</li>
                </ul>
            </div>
            <div class="ag-box glass-card">
                <div class="icon"><i class="fas fa-rocket"></i></div>
                <h3>Career Goals</h3>
                <ul>
                    <li>AI Engineer</li>
                    <li>Machine Learning Developer</li>
                    <li>Full-Stack Developer</li>
                </ul>
            </div>
        </div>
    </section>

    <!-- Projects Section -->
    <section id="projects" class="section fade-in">
        <h2 class="section-title">Future <span>Projects</span></h2>
        <div class="projects-grid">
            <div class="project-card glass-card">
                <div class="project-img placeholder-img">
                    <i class="fas fa-brain"></i>
                </div>
                <div class="project-info">
                    <h3>AI Predictive Model</h3>
                    <p>Future project focusing on machine learning and predictive analytics.</p>
                </div>
            </div>
            <div class="project-card glass-card">
                <div class="project-img placeholder-img">
                    <i class="fas fa-laptop-code"></i>
                </div>
                <div class="project-info">
                    <h3>Full-Stack Web App</h3>
                    <p>Future web development project using modern frameworks.</p>
                </div>
            </div>
            <div class="project-card glass-card">
                <div class="project-img placeholder-img">
                    <i class="fas fa-robot"></i>
                </div>
                <div class="project-info">
                    <h3>Computer Vision System</h3>
                    <p>Future machine learning project leveraging deep learning algorithms.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Contact Section -->
    <section id="contact" class="section fade-in">
        <h2 class="section-title">Contact <span>Me</span></h2>
        <div class="contact-container">
            <div class="contact-info glass-card">
                <h3>Let's Connect</h3>
                <p>I'm currently looking for new opportunities and collaborations.</p>
                <ul class="info-list">
                    <li><i class="fas fa-envelope"></i> ziya.momin@example.com</li>
                    <li><i class="fas fa-phone"></i> +91 00000 00000</li>
                    <li><i class="fas fa-map-marker-alt"></i> Pune, Maharashtra</li>
                </ul>
                <div class="social-links">
                    <a href="#" class="glow-icon"><i class="fab fa-github"></i></a>
                    <a href="#" class="glow-icon"><i class="fab fa-linkedin"></i></a>
                    <a href="#" class="glow-icon"><i class="fab fa-twitter"></i></a>
                </div>
            </div>
            <div class="contact-form glass-card">
                <form id="contactForm">
                    <div class="input-group">
                        <input type="text" id="name" required placeholder="Your Name">
                    </div>
                    <div class="input-group">
                        <input type="email" id="email" required placeholder="Your Email">
                    </div>
                    <div class="input-group">
                        <textarea id="message" rows="5" required placeholder="Your Message"></textarea>
                    </div>
                    <button type="submit" class="btn btn-primary glow-btn w-100">Send Message <i class="fas fa-paper-plane"></i></button>
                </form>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer>
        <div class="footer-content">
            <p>&copy; 2026 Ziya Samir Momin. All rights reserved.</p>
            <p>Designed with <i class="fas fa-heart" style="color: var(--primary);"></i> by an aspiring AI & ML Engineer.</p>
        </div>
        <a href="#hero" class="back-to-top glow-btn"><i class="fas fa-arrow-up"></i></a>
    </footer>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/particles.js@2.0.0/particles.min.js"></script>
    <script src="/js/script.js"></script>
